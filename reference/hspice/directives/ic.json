{
  "id": "hspice.directive.ic",
  "kind": "directive",
  "name": ".ic",
  "summary": "Force initial node voltages (HSPICE)",
  "syntax": ".IC V(node)=value [V(node2)=value2 ...]",
  "parameters": [
    { "name": "V(node)", "description": "Node (or hierarchical path) to initialize.", "units": "V" }
  ],
  "examples": [".IC V(out)=0", ".IC V(clk)=0 V(data)=1.8"],
  "seeAlso": ["hspice.directive.nodeset", "hspice.directive.tran"],
  "dialectNotes": "Also accepted as .DCVOLT. Used with .TRAN … UIC to skip the quiescent OP and start from these voltages."
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/amirhosseindavoody/spice-lsp/reference/schema.json",
  "title": "SPICE reference entry",
  "type": "object",
  "required": ["id", "kind", "name", "summary", "syntax"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "enum": ["directive", "element", "option", "expression"] },
    "name": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "syntax": { "type": "string", "minLength": 1 },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "units": { "type": "string" }
        }
      }
    },
    "examples": {
      "type": "array",
      "items": { "type": "string" }
    },
    "seeAlso": {
      "type": "array",
      "items": { "type": "string" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "since": { "type": "string" },
    "deprecated": { "type": "string" },
    "dialectNotes": { "type": "string" }
  }
}

{
  "name": "spice-lsp",
  "displayName": "SPICE Language Support",
  "description": "Language support for SPICE circuit simulation netlists — syntax diagnostics, outline, go to definition, and find references.",
  "version": "0.2.11",
  "publisher": "AmirhosseinDavoody",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amirhosseindavoody/spice-lsp.git"
  },
  "homepage": "https://github.com/amirhosseindavoody/spice-lsp",
  "bugs": {
    "url": "https://github.com/amirhosseindavoody/spice-lsp/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "spice",
    "ngspice",
    "hspice",
    "ltspice",
    "circuit",
    "netlist",
    "lsp",
    "simulation"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onLanguage:spice",
    "onCommand:spiceLsp.restartServer",
    "onCommand:spiceLsp.setDialect"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "spice",
        "aliases": [
          "SPICE",
          "spice"
        ],
        "extensions": [
          ".cir",
          ".sp",
          ".spf",
          ".net",
          ".ckt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "spice",
        "scopeName": "source.spice",
        "path": "./syntaxes/spice.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "SPICE LSP",
      "properties": {
        "spiceLsp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the spice-lsp binary. Leave empty to use the bundled binary for your platform."
        },
        "spiceLsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces communication between VS Code and the language server."
        },
        "spiceLsp.dialect": {
          "type": "string",
          "enum": [
            "hspice",
            "ngspice",
            "ltspice"
          ],
          "default": "hspice",
          "description": "Active SPICE dialect. Selects reference documentation for hover and future dialect-specific diagnostics. Default is HSPICE."
        }
      }
    },
    "commands": [
      {
        "command": "spiceLsp.restartServer",
        "title": "SPICE LSP: Restart Server"
      },
      {
        "command": "spiceLsp.setDialect",
        "title": "SPICE LSP: Set Dialect…"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.mjs",
    "check": "tsc -p ./ --noEmit",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
